{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Mesh Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Total Peers",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "auto" },
      "targets": [{ "expr": "wirekube_peers_total", "legendFormat": "peers" }]
    },
    {
      "title": "Relayed Peers",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "auto" },
      "targets": [{ "expr": "wirekube_relayed_peers_total", "legendFormat": "relayed" }]
    },
    {
      "title": "NAT Type",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "Unknown" }, "1": { "text": "Cone" }, "2": { "text": "Symmetric" } }, "type": "value" }
          ],
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 1 },
              { "color": "orange", "value": 2 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "auto" },
      "targets": [{ "expr": "wirekube_node_nat_type{node=~\"$node\"}", "legendFormat": "{{ node }}" }]
    },
    {
      "title": "Connected Peers",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "auto" },
      "targets": [{ "expr": "count(wirekube_peer_connected == 1)", "legendFormat": "connected" }]
    },
    {
      "title": "Peer Latency (ICMP RTT)",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "title": "Peer Latency (ms)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "pointSize": 5, "showPoints": "auto" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.2 }
            ]
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max", "last"] }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "wirekube_peer_latency_seconds{peer=~\"$peer\"}", "legendFormat": "{{ peer }} ({{ transport }})" }]
    },
    {
      "title": "Peer Latency Heatmap",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 0.05 },
              { "color": "red", "value": 0.2 }
            ]
          },
          "custom": { "displayMode": "color-background" }
        },
        "overrides": []
      },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "Value", "desc": true }] },
      "targets": [{ "expr": "wirekube_peer_latency_seconds", "legendFormat": "{{ peer }}", "format": "table", "instant": true }],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true, "endpoint": true }, "renameByName": { "peer": "Peer", "transport": "Transport", "Value": "RTT" } } }
      ]
    },
    {
      "title": "Transport Mode",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "Unknown" }, "1": { "text": "Direct", "color": "green" }, "2": { "text": "Relay", "color": "red" }, "3": { "text": "Mixed", "color": "yellow" } }, "type": "value" }
          ],
          "custom": { "displayMode": "color-background-solid" }
        },
        "overrides": []
      },
      "options": { "showHeader": true },
      "targets": [{ "expr": "wirekube_peer_transport_mode", "legendFormat": "{{ peer }}", "format": "table", "instant": true }],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true }, "renameByName": { "peer": "Peer", "Value": "Transport" } } }
      ]
    },
    {
      "title": "Traffic",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "collapsed": false
    },
    {
      "title": "Bytes Sent per Peer (rate)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 20 },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "rate(wirekube_peer_bytes_sent_total{peer=~\"$peer\"}[5m])", "legendFormat": "{{ peer }}" }]
    },
    {
      "title": "Bytes Received per Peer (rate)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 20 },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "rate(wirekube_peer_bytes_received_total{peer=~\"$peer\"}[5m])", "legendFormat": "{{ peer }}" }]
    },
    {
      "title": "Handshake & Health",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "collapsed": false
    },
    {
      "title": "Last Handshake Age",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5 },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 180 }
            ]
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "wirekube_peer_last_handshake_seconds{peer=~\"$peer\"}", "legendFormat": "{{ peer }}" }]
    },
    {
      "title": "Connection Status",
      "type": "state-timeline",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "Disconnected", "color": "red" }, "1": { "text": "Connected", "color": "green" } }, "type": "value" }
          ],
          "custom": { "fillOpacity": 70 }
        },
        "overrides": []
      },
      "options": { "showValue": "auto", "mergeValues": true, "alignValue": "left" },
      "targets": [{ "expr": "wirekube_peer_connected{peer=~\"$peer\"}", "legendFormat": "{{ peer }} ({{ nat_type }})" }]
    }
  ],
  "schemaVersion": 39,
  "tags": ["wirekube", "wireguard", "vpn"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(wirekube_peer_connected, peer)",
        "includeAll": true,
        "multi": true,
        "name": "peer",
        "query": "label_values(wirekube_peer_connected, peer)",
        "refresh": 2,
        "type": "query"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(wirekube_node_nat_type, node)",
        "includeAll": true,
        "multi": true,
        "name": "node",
        "query": "label_values(wirekube_node_nat_type, node)",
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "WireKube Mesh Overview",
  "uid": "wirekube-mesh",
  "version": 1
}
