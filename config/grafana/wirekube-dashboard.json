{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Mesh Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Total Peers",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value_and_name", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "max(wirekube_peers_total)", "legendFormat": "peers" }]
    },
    {
      "title": "Direct P2P",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value_and_name", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "max(wirekube_direct_peers_total{source=~\"$source\"})", "legendFormat": "direct" }]
    },
    {
      "title": "Relayed",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value_and_name", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "max(wirekube_relayed_peers_total{source=~\"$source\"})", "legendFormat": "relayed" }]
    },
    {
      "title": "This Node NAT",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "Unknown", "color": "blue" }, "1": { "text": "Cone", "color": "green" }, "2": { "text": "Symmetric", "color": "orange" }, "3": { "text": "Port-Restricted Cone", "color": "yellow" } }, "type": "value" }
          ],
          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value_and_name", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "wirekube_node_nat_type{node=~\"$source\"}", "legendFormat": "{{ node }}" }]
    },
    {
      "title": "NAT Type Distribution",
      "description": "NAT types across all mesh nodes.",
      "type": "piechart",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Cone" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Symmetric" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Port-Restricted Cone" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Unknown" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "right" }, "pieType": "donut", "reduceOptions": { "calcs": ["lastNotNull"] }, "tooltip": { "mode": "single" } },
      "targets": [
        { "expr": "count(wirekube_node_nat_type == 1)", "legendFormat": "Cone" },
        { "expr": "count(wirekube_node_nat_type == 2)", "legendFormat": "Symmetric" },
        { "expr": "count(wirekube_node_nat_type == 3)", "legendFormat": "Port-Restricted Cone" },
        { "expr": "count(wirekube_node_nat_type == 0)", "legendFormat": "Unknown" }
      ]
    },
    {
      "title": "Connected",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value_and_name", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "count(wirekube_peer_connected{source=~\"$source\"} == 1)", "legendFormat": "connected" }]
    },
    {
      "title": "Disconnected",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 5 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value_and_name", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "count(wirekube_peer_connected{source=~\"$source\"} == 0) or vector(0)", "legendFormat": "down" }]
    },

    {
      "title": "Peer Connectivity",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false
    },
    {
      "title": "Peer Transport (from $source)",
      "description": "Shows which peers use Direct P2P vs Relay transport from the selected source node's perspective.",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "custom": { "displayMode": "color-background-solid", "align": "center" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Transport" },
            "properties": [{
              "id": "mappings",
              "value": [{ "options": { "1": { "text": "Direct P2P ✓", "color": "green" }, "2": { "text": "Relay ⟳", "color": "red" } }, "type": "value" }]
            }]
          },
          {
            "matcher": { "id": "byName", "options": "ICE State" },
            "properties": [{
              "id": "mappings",
              "value": [{ "options": { "0": { "text": "relay" }, "1": { "text": "gathering" }, "2": { "text": "checking" }, "3": { "text": "connected", "color": "green" }, "4": { "text": "birthday" }, "5": { "text": "failed", "color": "red" } }, "type": "value" }]
            }]
          },
          {
            "matcher": { "id": "byName", "options": "NAT Type" },
            "properties": [{
              "id": "custom.displayMode", "value": "color-text"
            }]
          },
          {
            "matcher": { "id": "byName", "options": "Connected" },
            "properties": [{
              "id": "mappings",
              "value": [{ "options": { "0": { "text": "No", "color": "red" }, "1": { "text": "Yes", "color": "green" } }, "type": "value" }]
            }]
          },
          {
            "matcher": { "id": "byName", "options": "Latency" },
            "properties": [{ "id": "unit", "value": "s" }, { "id": "decimals", "value": 1 }]
          },
          {
            "matcher": { "id": "byName", "options": "Handshake Age" },
            "properties": [{ "id": "unit", "value": "s" }, { "id": "decimals", "value": 0 }]
          }
        ]
      },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "Transport", "desc": true }], "footer": { "enablePagination": false } },
      "targets": [
        { "expr": "wirekube_peer_transport_mode{source=~\"$source\"}", "legendFormat": "__auto", "format": "table", "instant": true, "refId": "A" },
        { "expr": "wirekube_peer_ice_state{source=~\"$source\"}", "legendFormat": "__auto", "format": "table", "instant": true, "refId": "B" },
        { "expr": "wirekube_peer_connected{source=~\"$source\"}", "legendFormat": "__auto", "format": "table", "instant": true, "refId": "C" },
        { "expr": "wirekube_peer_latency_seconds{source=~\"$source\"}", "legendFormat": "__auto", "format": "table", "instant": true, "refId": "D" },
        { "expr": "wirekube_peer_last_handshake_seconds{source=~\"$source\"}", "legendFormat": "__auto", "format": "table", "instant": true, "refId": "E" }
      ],
      "transformations": [
        { "id": "seriesToColumns", "options": { "byField": "peer" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "Time 1": true, "Time 2": true, "Time 3": true, "Time 4": true, "Time 5": true, "__name__": true, "__name__ 1": true, "__name__ 2": true, "__name__ 3": true, "__name__ 4": true, "instance": true, "instance 1": true, "instance 2": true, "instance 3": true, "instance 4": true, "job": true, "job 1": true, "job 2": true, "job 3": true, "job 4": true, "source": true, "source 1": true, "source 2": true, "source 3": true, "source 4": true, "endpoint": true, "transport": true },
            "renameByName": { "peer": "Peer", "Value #A": "Transport", "Value #B": "ICE State", "Value #C": "Connected", "Value #D": "Latency", "Value #E": "Handshake Age", "nat_type": "NAT Type" },
            "indexByName": { "Peer": 0, "NAT Type": 1, "Connected": 2, "Transport": 3, "ICE State": 4, "Latency": 5, "Handshake Age": 6 }
          }
        }
      ]
    },
    {
      "title": "Connection Status Timeline",
      "description": "Shows connection state changes over time. Green = connected, Red = disconnected.",
      "type": "state-timeline",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "Down", "color": "red" }, "1": { "text": "Up", "color": "green" } }, "type": "value" }
          ],
          "custom": { "fillOpacity": 80 }
        },
        "overrides": []
      },
      "options": { "showValue": "auto", "mergeValues": true, "alignValue": "left" },
      "targets": [{ "expr": "wirekube_peer_connected{source=~\"$source\"}", "legendFormat": "{{ peer }}" }]
    },

    {
      "title": "Latency & Performance",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false
    },
    {
      "title": "Direct P2P Latency",
      "description": "ICMP round-trip time to peers connected via direct P2P.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15, "pointSize": 4, "showPoints": "auto" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.2 }
            ]
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max", "last"] }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "wirekube_peer_latency_seconds{source=~\"$source\", transport=\"direct\"}", "legendFormat": "{{ peer }}" }]
    },
    {
      "title": "Relay Latency",
      "description": "ICMP round-trip time to peers connected via relay.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15, "pointSize": 4, "showPoints": "auto" },
          "thresholds": {
            "steps": [
              { "color": "yellow", "value": null },
              { "color": "orange", "value": 0.1 },
              { "color": "red", "value": 0.5 }
            ]
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max", "last"] }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "wirekube_peer_latency_seconds{source=~\"$source\", transport=\"relay\"}", "legendFormat": "{{ peer }} (relay)" }]
    },

    {
      "title": "Traffic",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "collapsed": false
    },
    {
      "title": "Throughput — Sent (per peer)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 28 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 20, "stacking": { "mode": "none" } },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "rate(wirekube_peer_bytes_sent_total{source=~\"$source\"}[5m])", "legendFormat": "→ {{ peer }}" }]
    },
    {
      "title": "Throughput — Received (per peer)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 28 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 20, "stacking": { "mode": "none" } },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "rate(wirekube_peer_bytes_received_total{source=~\"$source\"}[5m])", "legendFormat": "← {{ peer }}" }]
    },

    {
      "title": "Handshake Health",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 },
      "collapsed": false
    },
    {
      "title": "Last Handshake Age",
      "description": "Time since the last WireGuard handshake. Values > 180s indicate a stale or broken connection.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 36 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5 },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 180 }
            ]
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "wirekube_peer_last_handshake_seconds{source=~\"$source\"}", "legendFormat": "{{ peer }}" }]
    },
    {
      "title": "Transport Mode Over Time",
      "description": "Shows transport mode transitions (1=Direct, 2=Relay).",
      "type": "state-timeline",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 36 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "1": { "text": "Direct", "color": "green" }, "2": { "text": "Relay", "color": "orange" } }, "type": "value" }
          ],
          "custom": { "fillOpacity": 80 }
        },
        "overrides": []
      },
      "options": { "showValue": "auto", "mergeValues": true, "alignValue": "left" },
      "targets": [{ "expr": "wirekube_peer_transport_mode{source=~\"$source\"}", "legendFormat": "{{ peer }}" }]
    }
  ],
  "schemaVersion": 39,
  "tags": ["wirekube", "wireguard", "vpn"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "DS_PROMETHEUS",
        "label": "Datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(wirekube_peer_connected, source)",
        "includeAll": false,
        "multi": false,
        "name": "source",
        "label": "Source Node",
        "query": "label_values(wirekube_peer_connected, source)",
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "WireKube Mesh",
  "uid": "wirekube-mesh",
  "version": 2
}
